# ----------------------------------------------------------------------------
# Core / Main App
# -----------------------------------------------------------------------------

POSTGRES_USER=vectoplan
POSTGRES_PASSWORD=
POSTGRES_DB=vectoplan

FLASK_ENV=development
SECRET_KEY=

ADMIN_EMAIL=[admin@example.local](mailto:admin@example.local)
ADMIN_PW=

DOMAIN=localhost
SSL_ENABLED=false

VECTOPLAN_TOKEN=

# -----------------------------------------------------------------------------
# Stripe
# -----------------------------------------------------------------------------

STRIPE_SECRET_KEY=

# -----------------------------------------------------------------------------
# SMTP / Contact
# -----------------------------------------------------------------------------

SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
CONTACT_TO_ADDRESS=[info@example.local](mailto:info@example.local)

# -----------------------------------------------------------------------------
# Wiki.js
# -----------------------------------------------------------------------------

WIKI_DB_USER=wikijs
WIKI_DB_PASSWORD=
WIKI_DB_NAME=wikijs

WIKI_PUBLIC_URL=http://localhost:3001
WIKI_INTERNAL_URL=http://wiki:3000
WIKI_DEFAULT_PATH=

WIKI_ADMIN_EMAIL=[admin@example.local](mailto:admin@example.local)
WIKI_ADMIN_PASSWORD=

WIKI_CSP_FRAME_ANCESTORS=http://localhost:8000

# -----------------------------------------------------------------------------
# OpenAI
# -----------------------------------------------------------------------------

OPENAI_API_KEY=

# -----------------------------------------------------------------------------
# Google
# -----------------------------------------------------------------------------

GOOGLE_API_KEY=
GOOGLE_CX=

# -----------------------------------------------------------------------------
# Chat Defaults
# -----------------------------------------------------------------------------

DEFAULT_CHAT_MODEL=gpt-3.5-turbo
DEFAULT_CHAT_MAX_TOKENS=1500
DEFAULT_CHAT_TEMPERATURE=0.7

# -----------------------------------------------------------------------------
# Embedding
# -----------------------------------------------------------------------------

DEFAULT_EMBEDDING_MODEL=text-embedding-ada-002

# -----------------------------------------------------------------------------
# RabbitMQ
# -----------------------------------------------------------------------------

RABBITMQ_USER=vectoplan
RABBITMQ_PASSWORD=

# -----------------------------------------------------------------------------
# BPA / Redis
# -----------------------------------------------------------------------------

BPA_PORT=5744

REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PW=

# -----------------------------------------------------------------------------
# Mapbox / OpenLayer
# -----------------------------------------------------------------------------

MAPBOX_ACCESS_TOKEN=
MAPBOX_TOKEN=
MAPBOX_STYLE_URL=
MAPBOX_DEFAULT_STYLE=mapbox/satellite-streets-v12

# -----------------------------------------------------------------------------
# GeoServer Runtime
# -----------------------------------------------------------------------------

GEOSERVER_ADMIN_USER=admin
GEOSERVER_ADMIN_PASSWORD=

# -----------------------------------------------------------------------------
# GeoServer-Orchestrator
# -----------------------------------------------------------------------------

GEOSERVER_ORCHESTRATOR_ENV=development
GEOSERVER_ORCHESTRATOR_LOG_LEVEL=DEBUG

# -----------------------------------------------------------------------------
# Dedizierte PostgreSQL/PostGIS-Datenbank für den Geo-Orchestrator
# -----------------------------------------------------------------------------

GEOSERVER_ORCH_DB_DRIVER=postgresql+psycopg2
GEOSERVER_ORCH_DB_HOST=db
GEOSERVER_ORCH_DB_PORT=5432
GEOSERVER_ORCH_DB_NAME=geoserver_orchestrator_db
GEOSERVER_ORCH_DB_USER=geo_orch
GEOSERVER_ORCH_DB_PASSWORD=
GEOSERVER_ORCH_DB_OWNER=geo_orch

# -----------------------------------------------------------------------------
# PostgreSQL-Admin-Kontext für den Python-Bootstrap
# -----------------------------------------------------------------------------

PG_ADMIN_HOST=db
PG_ADMIN_PORT=5432
PG_ADMIN_DB=postgres
PG_ADMIN_USER=postgres
PG_ADMIN_PASSWORD=

# -----------------------------------------------------------------------------

# Ziel-Schemas innerhalb der dedizierten Geo-Orchestrator-Datenbank

# -----------------------------------------------------------------------------

META_SCHEMA_NAME=meta
MODEL_SCHEMA_NAME=meta
CATALOG_SCHEMA_NAME=meta
RAW_SCHEMA_NAME=raw
PUBLISH_SCHEMA_NAME=pub
EDITABLE_SCHEMA_NAME=edit
GEOSERVER_ORCH_SCHEMAS=meta,raw,pub,edit

# -----------------------------------------------------------------------------
# Default-Catalog für den GeoServer-Orchestrator
# -----------------------------------------------------------------------------

GEODATA_DEFAULT_CATALOG_KEY=default
GEODATA_DEFAULT_CATALOG_NAME=Default Catalog
GEODATA_DEFAULT_CATALOG_DESCRIPTION=Default catalog for GeoServer-Orchestrator geodata.

# -----------------------------------------------------------------------------
# Bootstrap-Verhalten für bootstrap_database.py
# -----------------------------------------------------------------------------

BOOTSTRAP_ENSURE_ROLE_IF_MISSING=true
BOOTSTRAP_UPDATE_ROLE_PASSWORD_IF_EXISTS=true
BOOTSTRAP_ENSURE_DATABASE_IF_MISSING=true
BOOTSTRAP_ALTER_DATABASE_OWNER_IF_NEEDED=true
BOOTSTRAP_ENSURE_POSTGIS_EXTENSION=true
BOOTSTRAP_ENSURE_SCHEMAS=true
BOOTSTRAP_ENSURE_SCHEMA_OWNERSHIP=true
BOOTSTRAP_GRANT_SCHEMA_PRIVILEGES=true
BOOTSTRAP_VERIFY_TARGET_CONNECTION=true
BOOTSTRAP_CREATE_MODEL_TABLES=true
BOOTSTRAP_VERIFY_MODEL_TABLES=true
BOOTSTRAP_ENSURE_DEFAULT_CATALOG=true

# -----------------------------------------------------------------------------
# Bootstrap-Verbindungs-Robustheit
# -----------------------------------------------------------------------------

BOOTSTRAP_CONNECT_MAX_ATTEMPTS=20
BOOTSTRAP_CONNECT_RETRY_SECONDS=2
BOOTSTRAP_CONNECT_TIMEOUT_SECONDS=10

# -----------------------------------------------------------------------------
# OGR / GeoPackage Import
# -----------------------------------------------------------------------------

OGR2OGR_COMMAND_TIMEOUT_SECONDS=7200
OGR_PG_USE_COPY=true

# -----------------------------------------------------------------------------

# Startup-Sync

# -----------------------------------------------------------------------------

STARTUP_SYNC_ENABLED=false
STARTUP_SYNC_CONTINUE_ON_ERROR=true
STARTUP_SYNC_FAIL_ON_ANY_FAILURE=false
STARTUP_SYNC_INCLUDE_INVALID=true
STARTUP_SYNC_VALIDATE_ONLY=false
STARTUP_SYNC_WRITE_STATE=true
STARTUP_SYNC_WRITE_SYNC_LOG=true
STARTUP_SYNC_INCLUDE_CATALOG=true
STARTUP_SYNC_ENRICH_CATALOG_WITH_DB=true
STARTUP_SYNC_EXPORT_SNAPSHOT=true
STARTUP_SYNC_FORCE_SOURCE_IMPORT=false
STARTUP_SYNC_DATASET_IDS=
