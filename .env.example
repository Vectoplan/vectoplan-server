# /vectoplan-website/services/vectoplan-server/.env.example

# ------------------------------------------------------------------------------
# VECTOPLAN Server Environment Example
# ------------------------------------------------------------------------------
# Zweck:
#   Öffentliche, sichere Beispielkonfiguration für das Submodule:
#
#     /services/vectoplan-server
#
# Diese Datei darf keine echten Secrets enthalten.
#
# Lokale Nutzung im öffentlichen Submodule:
#
#   cp .env.example .env
#   docker network create vectoplan-shared-net
#   docker compose -f docker-compose.all.yml up -d --build
#
# Nutzung aus dem privaten Root-Projekt /vectoplan-website:
#   Der Root-Orchestrator übergibt seine eigene private /vectoplan-website/.env.
#   Dieses Submodule darf nicht von privaten Root-Dateien abhängen.
#
# Sicherheit:
#   Host-Ports binden standardmäßig an 127.0.0.1.
#   Für LAN-Zugriff bewusst VECTOPLAN_HOST_BIND=0.0.0.0 setzen.
# ------------------------------------------------------------------------------

# ------------------------------------------------------------------------------
# Global
# ------------------------------------------------------------------------------

TZ=Europe/Berlin
LOG_LEVEL=INFO

VECTOPLAN_SERVER_PROJECT_NAME=vectoplan-server
VECTOPLAN_HOST_BIND=127.0.0.1
VECTOPLAN_SHARED_NETWORK=vectoplan-shared-net

VECTOPLAN_LOG_MAX_SIZE=10m
VECTOPLAN_LOG_MAX_FILE=3

DOCKER_BUILDKIT=1
COMPOSE_DOCKER_CLI_BUILD=1


# ------------------------------------------------------------------------------
# Public Host Ports
# ------------------------------------------------------------------------------
# Container-interne Ports bleiben stabil:
#   Editor/Library/Chunk: 5000
#   App:                  8000
#   GeoServer:            8080
#   Orchestrator:         8010
#   OpenLayer:            8090
#   PostgreSQL:           5432
#
# Nur Host-Ports müssen eindeutig sein.
# ------------------------------------------------------------------------------

VECTOPLAN_EDITOR_PUBLIC_PORT=5100
VECTOPLAN_LIBRARY_PUBLIC_PORT=5101
VECTOPLAN_CHUNK_PUBLIC_PORT=5102
VECTOPLAN_APP_PUBLIC_PORT=5103

GEOSERVER_ORCHESTRATOR_PUBLIC_PORT=5110
GEOSERVER_PUBLIC_PORT=5182
OPENLAYER_PUBLIC_PORT=5190

VECTOPLAN_LIBRARY_POSTGRES_PUBLIC_PORT=15432
VECTOPLAN_CHUNK_POSTGRES_PUBLIC_PORT=15433
VECTOPLAN_GEO_POSTGRES_PUBLIC_PORT=15434
VECTOPLAN_APP_POSTGRES_PUBLIC_PORT=15435


# ------------------------------------------------------------------------------
# Public URLs
# ------------------------------------------------------------------------------

VECTOPLAN_EDITOR_PUBLIC_URL=http://localhost:5100
VECTOPLAN_LIBRARY_PUBLIC_URL=http://localhost:5101
VECTOPLAN_CHUNK_PUBLIC_URL=http://localhost:5102
VECTOPLAN_APP_PUBLIC_URL=http://localhost:5103

GEOSERVER_ORCHESTRATOR_PUBLIC_URL=http://localhost:5110
GEOSERVER_PUBLIC_BASE_URL=http://localhost:5182/geoserver
OPENLAYER_PUBLIC_URL=http://localhost:5190


# ------------------------------------------------------------------------------
# Optional Cross-Project Boundary URLs
# ------------------------------------------------------------------------------
# Diese URLs sind nur relevant, wenn dieser Server-Stack im privaten Root-Modus B
# neben vectoplan-auth und vectoplan-platform läuft.
# ------------------------------------------------------------------------------

IDENTITY_INTERNAL_URL=http://identity:9000
REGISTRY_INTERNAL_URL=http://registry:8000

PLATFORM_WEB_INTERNAL_URL=http://flask-app:8000
PLATFORM_STRIPE_INTERNAL_URL=http://stripe-svc:8000


# ------------------------------------------------------------------------------
# Server Internal URLs
# ------------------------------------------------------------------------------

VECTOPLAN_EDITOR_INTERNAL_URL=http://vectoplan-editor:5000
VECTOPLAN_LIBRARY_INTERNAL_URL=http://vectoplan-library:5000
VECTOPLAN_CHUNK_INTERNAL_URL=http://vectoplan-chunk:5000
VECTOPLAN_APP_INTERNAL_URL=http://vectoplan-app:8000

GEOSERVER_ORCHESTRATOR_INTERNAL_URL=http://geoserver-orchestrator:8010
GEOSERVER_INTERNAL_BASE_URL=http://geoserver:8080/geoserver
OPENLAYER_INTERNAL_URL=http://openlayer:8090


# ------------------------------------------------------------------------------
# Runtime Users
# ------------------------------------------------------------------------------

VECTOPLAN_EDITOR_UID=10001
VECTOPLAN_EDITOR_GID=10001

VECTOPLAN_LIBRARY_UID=10002
VECTOPLAN_LIBRARY_GID=10002

VECTOPLAN_CHUNK_UID=10003
VECTOPLAN_CHUNK_GID=10003

GEOSERVER_RUN_UID=10001
GEOSERVER_RUN_GID=10001


# ------------------------------------------------------------------------------
# Editor Service
# ------------------------------------------------------------------------------

VECTOPLAN_EDITOR_CONFIG=development
VECTOPLAN_EDITOR_DEBUG=true
VECTOPLAN_EDITOR_HOST=0.0.0.0
VECTOPLAN_EDITOR_PORT=5000
VECTOPLAN_EDITOR_RUN_MODE=gunicorn

